{
  "name": "flowise",
  "version": "1.0.0",
  "description": "Drag & drop UI to build your customized LLM flow using LangchainJS",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo run clean",
    "nuke": "turbo run nuke && rimraf node_modules",
    "fresh": "npm run nuke && npm install && npm run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "eslint": "^8.38.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "prettier": "^2.8.7",
    "rimraf": "^5.0.0",
    "turbo": "^1.9.3",
    "typescript": "^5.0.4"
  },
  "engines": {
    "node": ">=18.15.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FlowiseAI/Flowise.git"
  },
  "license": "Apache-2.0",
  "keywords": [
    "langchain",
    "llm",
    "flowise",
    "ai",
    "chatbot"
  ],
  "_note": "Personal fork for learning LangchainJS integrations. Upstream: https://github.com/FlowiseAI/Flowise"
}
